    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "5.5.4",
    "vitest": "^2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
