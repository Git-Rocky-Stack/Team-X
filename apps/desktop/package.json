    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.24.0",
    "electron": "^31.0.0",
